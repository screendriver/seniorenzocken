{
	"parser": "@typescript-eslint/parser",
	"parserOptions": {
		"sourceType": "module",
		"ecmaVersion": 2020,
		"project": "tsconfig.json"
	},
	"extends": [
		"prettier",
		"eslint:recommended",
		"plugin:@typescript-eslint/eslint-recommended",
		"plugin:@typescript-eslint/recommended",
		"plugin:@typescript-eslint/recommended-requiring-type-checking",
		"plugin:prettier/recommended"
	],
	"plugins": ["@typescript-eslint", "functional", "unicorn", "deprecation"],
	"env": {
		"browser": true,
		"node": true
	},
	"rules": {
		"no-console": "error",
		"require-await": "error",
		"deprecation/deprecation": "error",
		"@typescript-eslint/explicit-function-return-type": [
			"error",
			{
				"allowExpressions": true,
				"allowTypedFunctionExpressions": true
			}
		],
		"@typescript-eslint/consistent-type-imports": "error",
		"functional/prefer-readonly-type": [
			"error",
			{
				"allowLocalMutation": true,
				"allowMutableReturnType": true,
				"checkImplicit": false,
				"ignoreClass": false,
				"ignoreInterface": false,
				"ignoreCollections": false
			}
		],
		"unicorn/prefer-node-protocol": "error",
		"unicorn/prefer-ternary": "error"
	},
	"overrides": [
		{
			"files": "src/start-develop.ts",
			"rules": {
				"no-console": "off"
			}
		},
		{
			"files": ["src/game/GamePoint.svelte.test.ts", "src/team/Team.svelte.test.ts"],
			"rules": {
				"@typescript-eslint/no-unsafe-member-access": "off",
				"@typescript-eslint/no-unsafe-assignment": "off",
				"@typescript-eslint/no-unsafe-call": "off"
			}
		},
		{
			"files": ["src/toggle-router/feature-decisions.test.ts", "src/game-state/game-state-machine.test.ts"],
			"rules": {
				"functional/prefer-readonly-type": "off"
			}
		}
	]
}
