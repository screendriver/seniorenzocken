{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"lib": ["ESNext.Disposable", "ES2024", "DOM", "DOM.Iterable"],
		"moduleDetection": "force",
		"jsx": "react-jsx"
	},
	"types": ["canvas-confetti", "lodash.sample"],
	"references": [{ "path": "../shared/tsconfig.json" }, { "path": "../server-shared/tsconfig.json" }],
	"include": ["./**/*.ts", "./**/*.tsx"]
}
