{
	"buildCommand": "npm run build",
	"devCommand": "npm run development",
	"framework": "svelte",
	"cleanUrls": true,
	"public": false,
	"outputDirectory": "target/dist/",
	"headers": [
		{
			"source": "/manifest.webmanifest",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/manifest+json"
				}
			]
		}
	]
}
