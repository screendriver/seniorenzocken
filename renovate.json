{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"labels": ["renovate"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true
	},
	"packageRules": [
		{
			"groupName": "Vite dependencies",
			"groupSlug": "vite",
			"matchPackageNames": ["vite", "@tailwindcss/vite", "vitest", "@vitest/*"]
		},
		{
			"groupName": "React dependencies",
			"groupSlug": "react",
			"matchPackageNames": [
				"react",
				"react-dom",
				"react-router-dom",
				"@types/react",
				"@types/react-dom",
				"@vitejs/plugin-react",
				"@testing-library/react",
				"@testing-library/user-event",
				"@radix-ui/*"
			]
		},
		{
			"groupName": "tRPC dependencies",
			"groupSlug": "trpc",
			"matchPackageNames": ["@trpc/*", "@hono/trpc-server"]
		},
		{
			"matchFileNames": [".woodpecker/*.yaml"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"matchPackageNames": ["eslint", "@enormora/eslint-config-*"],
			"groupName": "eslint packages"
		},
		{
			"matchPackageNames": ["@sentry/*"],
			"groupName": "sentry packages"
		},
		{
			"matchPackageNames": ["@tanstack/*"],
			"groupName": "tanstack packages"
		},
		{
			"matchDepTypes": ["dependencies", "devDependencies"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"groupName": "Node.js",
			"groupSlug": "nodejs",
			"matchPackageNames": ["node", "public.ecr.aws/docker/library/node"],
			"automerge": false
		}
	]
}
