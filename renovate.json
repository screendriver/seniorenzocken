{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"labels": ["renovate"],
	"lockFileMaintenance": {
		"enabled": true,
		"automerge": true
	},
	"packageRules": [
		{
			"groupName": "Pinia dependencies",
			"groupSlug": "pinia",
			"matchPackageNames": ["@pinia/*", "pinia"]
		},
		{
			"groupName": "tRPC dependencies",
			"groupSlug": "trpc",
			"matchPackageNames": ["@trpc/*", "@hono/trpc-server"]
		},
		{
			"matchFileNames": [".woodpecker/*.yaml"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		},
		{
			"matchPackageNames": ["eslint", "@enormora/eslint-config-*"],
			"groupName": "eslint packages"
		},
		{
			"matchPackageNames": ["@sentry/*"],
			"groupName": "sentry packages"
		},
		{
			"matchPackageNames": ["@tanstack/*"],
			"groupName": "tanstack packages"
		},
		{
			"matchDepTypes": ["dependencies", "devDependencies"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "branch"
		}
	]
}
