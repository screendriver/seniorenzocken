{
	"extends": "@tsconfig/node24/tsconfig.json",
	"include": ["source/server/**/*", "source/shared/**/*"],
	"compilerOptions": {
		"tsBuildInfoFile": "./target/tsconfig.node.tsbuildinfo",
		"target": "es2024",
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"importHelpers": true,

		"types": ["node"]
	}
}
